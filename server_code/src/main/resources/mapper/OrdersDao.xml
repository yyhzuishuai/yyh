<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cl.dao.OrdersDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.cl.entity.OrdersEntity" id="ordersMap">
        <result property="orderid" column="orderid"/>
        <result property="tablename" column="tablename"/>
        <result property="goodid" column="goodid"/>
        <result property="goodname" column="goodname"/>
        <result property="picture" column="picture"/>
        <result property="buynumber" column="buynumber"/>
        <result property="price" column="price"/>
        <result property="discountprice" column="discountprice"/>
        <result property="total" column="total"/>
        <result property="discounttotal" column="discounttotal"/>
        <result property="type" column="type"/>
        <result property="status" column="status"/>
        <result property="returnReason" column="return_reason"/>
        <result property="address" column="address"/>
        <result property="tel" column="tel"/>
        <result property="consignee" column="consignee"/>
        <result property="remark" column="remark"/>
        <result property="logistics" column="logistics"/>
        <result property="role" column="role"/>
        <result property="addtime" column="addtime"/>
        <result property="userid" column="userid"/>
        <result property="sfsh" column="sfsh"/>
        <result property="shhf" column="shhf"/>
        <result property="longitude" column="longitude"/>
        <result property="latitude" column="latitude"/>
        <result property="fulladdress" column="fulladdress"/>
        <result property="shangjiazhanghao" column="shangjiazhanghao"/>
        <result property="couponNumber" column="coupon_number"/>
        <result property="discountAmount" column="discount_amount"/>
        <result property="orderNo" column="order_no"/>
    </resultMap>

    <select id="selectListView"
		resultType="com.cl.entity.view.OrdersView" >

		SELECT  orders.* FROM orders  orders 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.cl.entity.view.OrdersView" >
		SELECT * FROM orders  orders <where> 1=1 ${ew.sqlSegment}</where>
	</select>



    <select id="selectValue" resultType="map" >
        SELECT ${params.xColumn},
        IFNULL(
        <choose>
            <when test="params.method == '总和'">sum(${params.yColumn})</when>
            <when test="params.method == '总数'">count(${params.yColumn})</when>
            <when test="params.method == '最大'">max(${params.yColumn})</when>
            <when test="params.method == '最小'">min(${params.yColumn})</when>
            <when test="params.method == '平均'">ROUND(avg(${params.yColumn}), 2)</when>
            <otherwise>sum(${params.yColumn})</otherwise>
        </choose>
        ,
        0) total FROM orders
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.xColumn}
        limit 10
    </select>

    <select id="selectTimeStatValue" resultType="map" >
        <if test = 'params.timeStatType == "日"'>
            SELECT DATE_FORMAT(${params.xColumn},'%Y-%m-%d') ${params.xColumn},
            IFNULL(
            <choose>
                <when test="params.method == '总和'">sum(${params.yColumn})</when>
                <when test="params.method == '总数'">count(${params.yColumn})</when>
                <when test="params.method == '最大'">max(${params.yColumn})</when>
                <when test="params.method == '最小'">min(${params.yColumn})</when>
                <when test="params.method == '平均'">ROUND(avg(${params.yColumn}), 2)</when>
                <otherwise>sum(${params.yColumn})</otherwise>
            </choose>
            ,
            0) total FROM orders
            <where> 1=1 ${ew.sqlSegment}</where>
            group by DATE_FORMAT(${params.xColumn},'%Y-%m-%d')
        </if>
        <if test='params.timeStatType == "周"'>
            -- 1、按年和周数值分组
            -- 2、先按年降序，再按周降序
            SELECT CONCAT(YEAR(${params.xColumn}), '年 第', WEEK(${params.xColumn}, 1), '周') AS ${params.xColumn},
            IFNULL(
            <choose>
                <when test="params.method == '总和'">sum(${params.yColumn})</when>
                <when test="params.method == '总数'">count(${params.yColumn})</when>
                <when test="params.method == '最大'">max(${params.yColumn})</when>
                <when test="params.method == '最小'">min(${params.yColumn})</when>
                <when test="params.method == '平均'">ROUND(avg(${params.yColumn}), 2)</when>
                <otherwise>sum(${params.yColumn})</otherwise>
            </choose>
            ,
            0) total FROM orders
            <where> 1=1 ${ew.sqlSegment}</where>
            GROUP BY YEAR(${params.xColumn}), WEEK(${params.xColumn}, 1)
            ORDER BY YEAR(${params.xColumn}) DESC, WEEK(${params.xColumn}, 1) DESC
        </if>
        <if test = 'params.timeStatType == "月"'>
            SELECT DATE_FORMAT(${params.xColumn},'%Y-%m') ${params.xColumn},
            IFNULL(
            <choose>
                <when test="params.method == '总和'">sum(${params.yColumn})</when>
                <when test="params.method == '总数'">count(${params.yColumn})</when>
                <when test="params.method == '最大'">max(${params.yColumn})</when>
                <when test="params.method == '最小'">min(${params.yColumn})</when>
                <when test="params.method == '平均'">ROUND(avg(${params.yColumn}), 2)</when>
                <otherwise>sum(${params.yColumn})</otherwise>
            </choose>
            ,
            0) total FROM orders
            <where> 1=1 ${ew.sqlSegment}</where>
            group by DATE_FORMAT(${params.xColumn},'%Y-%m')
        </if>
        <if test='params.timeStatType == "季"'>
            SELECT CONCAT(YEAR(${params.xColumn}), ' - ', ELT(QUARTER(${params.xColumn}), '第一季度', '第二季度', '第三季度', '第四季度')) as ${params.xColumn},
            IFNULL(
            <choose>
                <when test="params.method == '总和'">sum(${params.yColumn})</when>
                <when test="params.method == '总数'">count(${params.yColumn})</when>
                <when test="params.method == '最大'">max(${params.yColumn})</when>
                <when test="params.method == '最小'">min(${params.yColumn})</when>
                <when test="params.method == '平均'">ROUND(avg(${params.yColumn}), 2)</when>
                <otherwise>sum(${params.yColumn})</otherwise>
            </choose>
            ,
            0) total FROM orders
            <where> 1=1 ${ew.sqlSegment}</where>
            group by CONCAT(YEAR(${params.xColumn}), ' - ', ELT(QUARTER(${params.xColumn}), '第一季度', '第二季度', '第三季度', '第四季度'))
        </if>
        <if test = 'params.timeStatType == "年"'>
            SELECT DATE_FORMAT(${params.xColumn},'%Y') ${params.xColumn},
            IFNULL(
            <choose>
                <when test="params.method == '总和'">sum(${params.yColumn})</when>
                <when test="params.method == '总数'">count(${params.yColumn})</when>
                <when test="params.method == '最大'">max(${params.yColumn})</when>
                <when test="params.method == '最小'">min(${params.yColumn})</when>
                <when test="params.method == '平均'">ROUND(avg(${params.yColumn}), 2)</when>
                <otherwise>sum(${params.yColumn})</otherwise>
            </choose>
            ,
            0) total FROM orders
            <where> 1=1 ${ew.sqlSegment}</where>
            group by DATE_FORMAT(${params.xColumn},'%Y')
        </if>
    </select>

    <select id="selectGroup" resultType="map" >
        SELECT ${params.column} , count(1) total FROM orders
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.column}
        limit 10
    </select>



</mapper>
