<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cl.dao.RechargeRecordDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.cl.entity.RechargeRecordEntity" id="rechargeRecordMap">
        <result property="username" column="username"/>
        <result property="role" column="role"/>
        <result property="amount" column="amount"/>
        <result property="userid" column="userid"/>
    </resultMap>

    <select id="selectListView"
		resultType="com.cl.entity.view.RechargeRecordView" >

		SELECT  recharge_record.* FROM recharge_record  recharge_record 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.cl.entity.view.RechargeRecordView" >
		SELECT * FROM recharge_record  recharge_record <where> 1=1 ${ew.sqlSegment}</where>
	</select>



</mapper>
