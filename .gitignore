# Root ignore for both front-end and back-end
# Node projects
/manage_code/node_modules/
/client_code/node_modules/
/manage_code/dist/
/client_code/dist/
/manage_code/.cache/
/client_code/.cache/

# Logs
*.log
*.pid
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Env files
.env
.env.*.local

# Editor
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db

# Build outputs
/server_code/target/
/server_code/*.war
/server_code/*.jar

# Coverage
coverage/

# Misc
/.trae/
